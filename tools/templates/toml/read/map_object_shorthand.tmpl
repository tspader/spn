static void spn_cg_{{ .entry }}_read_map(spn_toml_loader_t* ctx, toml_table_t* table, const c8* key, sp_da({{ .entry_type }})* out) {
  toml_table_t* child = toml_table_table(table, key);
  if (!child) {
    return;
  }
  *out = sp_da_new(ctx->mem, {{ .entry_type }});
  spn_toml_loader_push_key(ctx, key);
  sp_for(it, (u32)toml_table_len(child)) {
    s32 len = 0;
    const c8* name = toml_table_key(child, (s32)it, &len);
    if (!name) {
      break;
    }
    {{ .entry_type }} entry = sp_zero;
    entry.key = spn_toml_loader_intern(ctx, sp_str(name, (u32)len));
    toml_table_t* value = toml_table_table(child, name);
    if (value) {
      spn_toml_loader_push_key(ctx, name);
      spn_cg_{{ .object }}_read(ctx, value, &entry.value);
      spn_toml_loader_pop(ctx);
    } else {
      spn_toml_loader_str_optional(ctx, child, name, &entry.value.{{ .shorthand }});
    }
    sp_da_push(*out, entry);
  }
  spn_toml_loader_pop(ctx);
}
