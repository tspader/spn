{
  "ref": "toolchains",
  "definitions": {
    "arch":      { "enum": ["x86_64", "aarch64"] },
    "os":        { "enum": ["windows", "linux", "macos"] },
    "abi":       { "enum": ["gnu", "musl", "msvc", "mingw"] },
    "cc_driver": { "enum": ["gcc", "clang", "msvc"] },

    "toolchains": {
      "optionalProperties": {
        "toolchain": { "elements": { "ref": "toolchain" } }
      }
    },

    "triple": {
      "optionalProperties": {
        "arch": { "ref": "arch" },
        "os":   { "ref": "os" },
        "abi":  { "ref": "abi" }
      }
    },

    "launcher": {
      "properties":         { "program": { "type": "string" } },
      "optionalProperties": { "args": { "elements": { "type": "string" } } }
    },

    "dist": {
      "properties": {
        "url":    { "type": "string" },
        "sha256": { "type": "string" }
      }
    },

    "toolchain": {
      "properties": {
        "name":     { "type": "string" },
        "version":  { "type": "string" },
        "driver":   { "ref": "cc_driver" },
        "compiler": { "ref": "launcher" },
        "linker":   { "ref": "launcher" },
        "archiver": { "ref": "launcher" },
        "host":     { "values": { "ref": "dist" } },
        "target":   { "elements": { "ref": "triple" } }
      },
      "optionalProperties": {
        "sysroot":     { "type": "string" },
        "mirror_list": { "type": "string" }
      }
    }
  }
}
