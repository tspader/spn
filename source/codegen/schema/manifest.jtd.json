{
  "metadata": { "format": "toml" },
  "properties": {
    "package": { "ref": "package" }
  },
  "optionalProperties": {
    "lib": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
    "bin": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
    "script": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
    "test": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
    "toolchain": { "elements": { "ref": "manifest_toolchain" } },
    "index": { "elements": { "ref": "index" }, "metadata": { "key": "name" } },
    "profile": { "values": { "ref": "profile" } },
    "options": { "values": { "ref": "option" } },
    "deps": { "ref": "deps" },
    "config": { "values": { "ref": "config_entry" } },
    "publish": { "ref": "publish" }
  },
  "definitions": {
    "c_standard": { "enum": ["c89", "c99", "c11"] },
    "cxx_standard": { "enum": ["c++11", "c++14", "c++17", "c++20", "c++23"] },
    "build_mode": { "enum": ["release", "debug"] },
    "index_protocol": { "enum": ["git", "http", "filesystem"], "metadata": { "include": "index/types.h" } },
    "option_type": { "enum": ["bool", "enum"], "metadata": { "include": "when/types.h" } },

    "option": {
      "properties": {
        "type": { "ref": "option_type" }
      },
      "optionalProperties": {
        "values": { "elements": { "type": "string" } },
        "default": { "metadata": { "extern": "option_defaults", "field": "defaults", "include": "when/types.h" } }
      }
    },

    "source_entry": {
      "properties": {
        "path": { "type": "string" }
      },
      "optionalProperties": {
        "when": { "metadata": { "extern": "when", "include": "when/types.h" } }
      }
    },

    "value_entry": {
      "properties": {
        "value": { "type": "string" }
      },
      "optionalProperties": {
        "when": { "metadata": { "extern": "when", "include": "when/types.h" } }
      }
    },

    "publish": {
      "optionalProperties": {
        "copy": { "elements": { "ref": "publish_copy" } }
      }
    },

    "publish_copy": {
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" }
      }
    },

    "package": {
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      },
      "optionalProperties": {
        "namespace": { "type": "string" },
        "url": { "type": "string" },
        "repo": { "type": "string" },
        "author": { "type": "string" },
        "maintainer": { "type": "string" },
        "commit": { "type": "string" },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "type": "string" } },
        "system_deps": { "elements": { "type": "string" } },
        "build": { "ref": "build_script" },
        "configure": { "ref": "build_script" }
      }
    },

    "build_script": {
      "optionalProperties": {
        "source": { "elements": { "type": "string" } },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "type": "string" } },
        "flags": { "elements": { "type": "string" } }
      }
    },

    "target": {
      "properties": {
        "name": { "type": "string" }
      },
      "optionalProperties": {
        "kinds": { "elements": { "type": "string" } },
        "source": { "elements": { "ref": "source_entry" }, "metadata": { "shorthand": "path" } },
        "headers": { "elements": { "type": "string" } },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "ref": "value_entry" }, "metadata": { "shorthand": "value" } },
        "flags": { "elements": { "ref": "value_entry" }, "metadata": { "shorthand": "value" } },
        "system_deps": { "elements": { "ref": "value_entry" }, "metadata": { "shorthand": "value" } },
        "deps": { "elements": { "type": "string" } },
        "link": { "type": "boolean" },
        "cxx": { "ref": "cxx_options" }
      }
    },

    "cxx_options": {
      "optionalProperties": {
        "standard": { "ref": "cxx_standard" },
        "exceptions": { "type": "boolean" },
        "rtti": { "type": "boolean" }
      }
    },

    "manifest_toolchain": {
      "optionalProperties": {
        "name": { "type": "string" },
        "compiler": { "type": "string" },
        "linker": { "type": "string" },
        "archiver": { "type": "string" },
        "driver": { "ref": "cc_driver" },
        "cxx": { "type": "string" },
        "host": { "values": { "ref": "artifact" } },
        "mirrors": { "type": "string" },
        "target": { "elements": { "ref": "triple" } }
      }
    },

    "profile": {
      "optionalProperties": {
        "linkage": { "ref": "linkage" },
        "standard": { "ref": "c_standard" },
        "toolchain": { "type": "string" },
        "mode": { "ref": "build_mode" },
        "os": { "ref": "os" },
        "arch": { "ref": "arch" },
        "abi": { "ref": "abi" }
      }
    },

    "index": {
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "protocol": { "ref": "index_protocol" }
      }
    },

    "deps": {
      "optionalProperties": {
        "package": { "values": { "ref": "dep" }, "metadata": { "shorthand": "version" } },
        "test": { "values": { "ref": "dep" }, "metadata": { "shorthand": "version" } },
        "build": { "values": { "ref": "dep" }, "metadata": { "shorthand": "version" } }
      }
    },

    "dep": {
      "properties": {
        "version": { "type": "string" }
      },
      "optionalProperties": {
        "private": { "type": "boolean" },
        "when": { "metadata": { "extern": "when", "include": "when/types.h" } }
      }
    },

    "config_entry": {
      "optionalProperties": {
        "kind": { "ref": "linkage" }
      }
    }
  }
}
