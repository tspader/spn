{
  "metadata": { "format": "json" },
  "properties": {
    "namespace": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "yanked": { "type": "boolean" }
  },
  "optionalProperties": {
    "source": { "ref": "release_source" },
    "manifest": { "ref": "release_source" },
    "paths": { "ref": "release_paths" },
    "deps": { "elements": { "ref": "release_dep" } },
    "targets": { "elements": { "ref": "release_target" } },
    "options": { "values": { "ref": "release_option" } }
  },
  "definitions": {
    "index_dep_kind": { "enum": ["normal", "build", "test"], "metadata": { "include": "index/types.h" } },

    "release_source": {
      "optionalProperties": {
        "url": { "type": "string" },
        "rev": { "type": "string" },
        "dir": { "type": "string" }
      }
    },

    "release_paths": {
      "optionalProperties": {
        "manifest": { "type": "string" },
        "script": { "type": "string" }
      }
    },

    "release_dep": {
      "properties": {
        "namespace": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "kind": { "ref": "index_dep_kind" }
      },
      "optionalProperties": {
        "private": { "type": "boolean" },
        "when": { "metadata": { "extern": "when", "include": "when/types.h" } },
        "options": { "metadata": { "extern": "when", "include": "when/types.h" } }
      }
    },

    "release_option": {
      "properties": {
        "type": { "ref": "option_type" }
      },
      "optionalProperties": {
        "values": { "elements": { "type": "string" } },
        "default": { "metadata": { "extern": "option_defaults", "field": "defaults", "include": "when/types.h" } },
        "additive": { "type": "boolean" }
      }
    },

    "release_target": {
      "properties": {
        "name": { "type": "string" },
        "linkages": { "elements": { "ref": "linkage" } }
      }
    }
  }
}
