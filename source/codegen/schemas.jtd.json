{
  "definitions": {
    "arch": { "enum": ["x86_64", "aarch64", "wasm32"] },
    "os": { "enum": ["windows", "linux", "macos", "wasi"] },
    "abi": { "enum": ["gnu", "musl", "msvc", "mingw"] },
    "cc_driver": { "enum": ["gcc", "clang", "msvc"] },
    "linkage": { "enum": ["shared", "static", "source", "object"] },
    "c_standard": { "enum": ["c89", "c99", "c11"] },
    "build_mode": { "enum": ["release", "debug"] },
    "index_protocol": { "enum": ["git", "http", "filesystem"] },

    "triple": {
      "optionalProperties": {
        "arch": { "ref": "arch" },
        "os": { "ref": "os" },
        "abi": { "ref": "abi" }
      }
    },

    "manifest": {
      "metadata": { "renderer": "toml" },
      "properties": {
        "package": { "ref": "package" }
      },
      "optionalProperties": {
        "lib": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
        "bin": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
        "script": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
        "test": { "elements": { "ref": "target" }, "metadata": { "key": "name" } },
        "toolchain": { "elements": { "ref": "manifest_toolchain" } },
        "index": { "elements": { "ref": "index" }, "metadata": { "key": "name" } },
        "profile": { "values": { "ref": "profile" } },
        "deps": { "ref": "deps" },
        "config": { "values": { "ref": "config_entry" } }
      }
    },

    "package": {
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      },
      "optionalProperties": {
        "namespace": { "type": "string" },
        "url": { "type": "string" },
        "repo": { "type": "string" },
        "author": { "type": "string" },
        "maintainer": { "type": "string" },
        "commit": { "type": "string" },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "type": "string" } },
        "system_deps": { "elements": { "type": "string" } },
        "build": { "type": "string" },
        "configure": { "type": "string" }
      }
    },

    "target": {
      "properties": {
        "name": { "type": "string" }
      },
      "optionalProperties": {
        "kinds": { "elements": { "type": "string" } },
        "source": { "elements": { "type": "string" } },
        "headers": { "elements": { "type": "string" } },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "type": "string" } },
        "flags": { "elements": { "type": "string" } },
        "deps": { "elements": { "type": "string" } },
        "link": { "type": "boolean" }
      }
    },

    "manifest_toolchain": {
      "optionalProperties": {
        "name": { "type": "string" },
        "compiler": { "type": "string" },
        "linker": { "type": "string" },
        "archiver": { "type": "string" },
        "driver": { "ref": "cc_driver" },
        "host": { "values": { "ref": "artifact" } },
        "mirrors": { "type": "string" },
        "target": { "elements": { "ref": "triple" } }
      }
    },

    "profile": {
      "optionalProperties": {
        "linkage": { "ref": "linkage" },
        "standard": { "ref": "c_standard" },
        "toolchain": { "type": "string" },
        "mode": { "ref": "build_mode" },
        "os": { "ref": "os" },
        "arch": { "ref": "arch" },
        "abi": { "ref": "abi" }
      }
    },

    "index": {
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "protocol": { "ref": "index_protocol" }
      }
    },

    "deps": {
      "optionalProperties": {
        "package": { "values": { "type": "string" } },
        "test": { "values": { "type": "string" } },
        "build": { "values": { "type": "string" } }
      }
    },

    "config_entry": {
      "optionalProperties": {
        "kind": { "ref": "linkage" }
      }
    },

    "run_std": {
      "optionalProperties": {
        "out": { "type": "string" }
      }
    },

    "run": {
      "metadata": { "renderer": "abi" },
      "optionalProperties": {
        "target": { "type": "uint32", "metadata": { "handle": "target" } },
        "args": { "elements": { "type": "string" }, "metadata": { "cap": "16" } },
        "std": { "ref": "run_std" }
      }
    },

    "toolchains": {
      "metadata": { "renderer": "json" },
      "optionalProperties": {
        "toolchain": { "elements": { "ref": "toolchain" }, "metadata": { "key": "name" } }
      }
    },

    "launcher": {
      "properties":         { "program": { "type": "string" } },
      "optionalProperties": { "args": { "elements": { "type": "string" } } }
    },

    "artifact": {
      "properties": {
        "url": { "type": "string" }
      },
      "optionalProperties": {
        "sha256": { "type": "string" }
      }
    },

    "toolchain": {
      "properties": {
        "name":     { "type": "string" },
        "driver":   { "ref": "cc_driver" },
        "compiler": { "ref": "launcher" },
        "linker":   { "ref": "launcher" },
        "archiver": { "ref": "launcher" }
      },
      "optionalProperties": {
        "version":  { "type": "string" },
        "host":     { "values": { "ref": "artifact" } },
        "target":   { "elements": { "ref": "triple" } },
        "mirrors":  { "type": "string" }
      }
    }
  }
}
