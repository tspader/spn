{
  "ref": "manifest",
  "definitions": {
    "arch": { "enum": ["x86_64", "aarch64"] },
    "os": { "enum": ["windows", "linux", "macos"] },
    "abi": { "enum": ["gnu", "musl", "msvc", "mingw"] },
    "cc_driver": { "enum": ["gcc", "clang", "msvc"] },
    "linkage": { "enum": ["shared", "static", "source", "object"] },
    "c_standard": { "enum": ["c89", "c99", "c11"] },
    "build_mode": { "enum": ["release", "debug"] },
    "index_protocol": { "enum": ["git", "http", "filesystem"] },

    "manifest": {
      "properties": {
        "package": { "ref": "package" }
      },
      "optionalProperties": {
        "lib": { "elements": { "ref": "target" } },
        "bin": { "elements": { "ref": "target" } },
        "script": { "elements": { "ref": "target" } },
        "test": { "elements": { "ref": "target" } },
        "toolchain": { "elements": { "ref": "toolchain" } },
        "index": { "elements": { "ref": "index" } },
        "profile": { "values": { "ref": "profile" } },
        "deps": { "ref": "deps" }
      }
    },

    "package": {
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string", "metadata": { "convert": "enum", "enum": "semver" } }
      },
      "optionalProperties": {
        "namespace": { "type": "string" },
        "url": { "type": "string" },
        "repo": { "type": "string" },
        "author": { "type": "string" },
        "maintainer": { "type": "string" },
        "commit": { "type": "string" },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "type": "string" } },
        "system_deps": { "elements": { "type": "string" } }
      }
    },

    "target": {
      "properties": {
        "name": { "type": "string" }
      },
      "optionalProperties": {
        "kinds": { "elements": { "type": "string" } },
        "source": { "elements": { "type": "string" } },
        "headers": { "elements": { "type": "string" } },
        "include": { "elements": { "type": "string" } },
        "define": { "elements": { "type": "string" } },
        "flags": { "elements": { "type": "string" } },
        "deps": { "elements": { "type": "string" } },
        "link": { "type": "boolean" }
      }
    },

    "triple": {
      "optionalProperties": {
        "arch": { "ref": "arch" },
        "os": { "ref": "os" },
        "abi": { "ref": "abi" }
      }
    },

    "toolchain": {
      "optionalProperties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "compiler": { "type": "string" },
        "linker": { "type": "string" },
        "archiver": { "type": "string" },
        "sysroot": { "type": "string" },
        "driver": { "ref": "cc_driver" },
        "package": { "type": "string" },
        "version": { "type": "string" },
        "export": { "type": "boolean" },
        "host": { "elements": { "ref": "triple" } },
        "target": { "elements": { "ref": "triple" } }
      }
    },

    "profile": {
      "optionalProperties": {
        "linkage": { "ref": "linkage" },
        "standard": { "ref": "c_standard" },
        "toolchain": { "type": "string" },
        "mode": { "ref": "build_mode" },
        "os": { "ref": "os" },
        "arch": { "ref": "arch" },
        "abi": { "ref": "abi" }
      }
    },

    "index": {
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "protocol": { "ref": "index_protocol" }
      }
    },

    "deps": {
      "optionalProperties": {
        "package": { "values": { "type": "string" } },
        "test": { "values": { "type": "string" } },
        "build": { "values": { "type": "string" } }
      }
    }
  }
}
