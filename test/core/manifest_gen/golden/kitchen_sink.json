{
  "package": {
    "name": "everything",
    "version": "1.0.0",
    "namespace": "core",
    "url": "https://example.com/everything",
    "repo": "https://github.com/acme/everything",
    "author": "Ada",
    "maintainer": "Grace",
    "commit": "cafef00d",
    "include": [
      "include"
    ],
    "define": [
      "BUILD=1"
    ],
    "system_deps": [
      "m"
    ],
    "qualified": "core/everything",
    "versions": [
      {
        "version": "1.0.0",
        "commit": "cafef00d"
      }
    ]
  },
  "lib": {
    "everything": {
      "name": "everything",
      "kinds": [
        "static",
        "shared"
      ],
      "source": [
        "lib.c"
      ],
      "headers": [
        "everything.h"
      ],
      "include": [
        "include"
      ],
      "define": [
        "LIB=1"
      ],
      "flags": [
        "-Wall"
      ],
      "deps": [
        "libfoo"
      ],
      "link": true
    }
  },
  "bin": {
    "everything-cli": {
      "name": "everything-cli",
      "source": [
        "main.c"
      ],
      "deps": [
        "everything"
      ]
    }
  },
  "script": {
    "postbuild": {
      "name": "postbuild",
      "source": [
        "post.sh"
      ]
    }
  },
  "test": {
    "everything-test": {
      "name": "everything-test",
      "source": [
        "test.c"
      ],
      "deps": [
        "everything"
      ]
    }
  },
  "toolchain": [
    {
      "name": "host-gcc",
      "compiler": {
        "program": "gcc"
      },
      "linker": {
        "program": "ld"
      },
      "archiver": {
        "program": "ar"
      },
      "driver": "gcc",
      "version": "13.2",
      "export": true,
      "host": [
        {
          "arch": "x86_64",
          "os": "linux",
          "abi": "gnu"
        }
      ],
      "target": [
        {
          "arch": "aarch64",
          "os": "linux"
        }
      ]
    }
  ],
  "index": {
    "core": {
      "name": "core",
      "url": "https://packages.example.com",
      "protocol": "http",
      "kind": "workspace"
    },
    "local": {
      "name": "local",
      "url": "/srv/pkgs",
      "protocol": "filesystem",
      "kind": "workspace"
    }
  },
  "profile": {
    "debug": {
      "standard": "c11",
      "mode": "debug"
    },
    "release": {
      "linkage": "static",
      "mode": "release"
    }
  },
  "deps": {
    "package": {
      "libfoo": "^1.0.0"
    },
    "test": {
      "utest": "1.0.0"
    },
    "build": {
      "cmake": "3.20"
    }
  }
}